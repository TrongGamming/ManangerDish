    <header class="header">
        <nav class="navbar navbar-expand-lg navbar-light bg-white fixed-top">
            <div class="container">
                <a class="navbar-brand" href="#">
                    <img src="images/manwah-logo.png"
                         alt="Manwah Logo"
                         height="50" />
                </a>
                <button class="navbar-toggler"
                        type="button"
                        data-bs-toggle="collapse"
                        data-bs-target="#navbarNav">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="collapse navbar-collapse" id="navbarNav">
                    <ul class="navbar-nav ms-auto">
                        <li class="nav-item">
                            <a class="nav-link active" href="#home">Trang chủ</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" href="#menu">Thực đơn</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" href="#promotions">Ưu đãi</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" href="#locations">Hệ thống nhà hàng</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" href="#reservation">Đặt bàn</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" href="#about">Về Manwah</a>
                        </li>
                    </ul>
                </div>
            </div>
        </nav>
    </header>
    <main role="main" class="pb-3">
        @RenderBody()
    </main>

    <footer class="footer bg-dark text-white py-4">
        <div class="container">
            <div class="row">
                <div class="col-lg-4">
                    <h5>Liên hệ</h5>
                    <p>
                        <i class="fas fa-map-marker-alt"></i> 123 Đường ABC,
                        Quận 1, TP.HCM
                    </p>
                    <p><i class="fas fa-phone"></i> (028) 1234 5678</p>
                    <p><i class="fas fa-envelope"></i> info@manwah.com</p>
                </div>
                <div class="col-lg-4">
                    <h5>Giờ mở cửa</h5>
                    <p>Thứ 2 - Thứ 6: 10:00 - 22:00</p>
                    <p>Thứ 7 - Chủ nhật: 09:00 - 23:00</p>
                </div>
                <div class="col-lg-4">
                    <h5>Theo dõi chúng tôi</h5>
                    <div class="social-links">
                        <a href="#"><i class="fab fa-facebook"></i></a>
                        <a href="#"><i class="fab fa-instagram"></i></a>
                        <a href="#"><i class="fab fa-youtube"></i></a>
                    </div>
                </div>
            </div>
            <div class="row mt-3">
                <div class="col-12 text-center">
                    <p class="mb-0">
                        &copy; 2024 Manwah Hotpot. All rights reserved.
                    </p>
                </div>
            </div>
        </div>
    </footer>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
