<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - ManagerDish</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/ManagerDish.styles.css" asp-append-version="true" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.12.1/font/bootstrap-icons.min.css">
</head>
<body>
    <main class="d-flex">
        <!-- Sidebar -->
        <input type="checkbox" id="sidebar__check" class="sidebar__check" />
        <aside class="bg-light sidebar position-fixed shadow-sm min-vh-100" >
            <h3 class="text-center sidebar__heading  mt-4">Admin</h3>
            <label for="sidebar__check" class="sidebar__label m-0"><i class="bi bi-list p-3 sidebar__icon fs-3 ms-2"></i></label>
            <ul class="list-unstyled">
                <li class="">
                    <a asp-area="Admin" asp-controller="Account" asp-action="Accounts" class="text-decoration-none text-dark p-3 d-flex align-items-center">
                        <i class="bi text-primary px-2 fs-3 me-3 bi-person-vcard-fill"></i> Accounts
                    </a>
                </li>
                <li class="">
                    <a asp-area="Admin" asp-controller="Dish" asp-action="Dishes" class="text-decoration-none text-dark p-3 d-flex align-items-center">
                        <i class="bi px-2 fs-3 me-3 text-primary bi-egg-fill"></i> Dishes
                    </a>
                </li>
                <li class="">
                    <a asp-area="Admin" asp-controller="Order" asp-action="Orders" class="text-decoration-none p-3 text-dark d-flex align-items-center">
                        <i class="bi px-2 fs-3 me-3 text-primary bi-journal-bookmark"></i> Orders
                    </a>
                </li>
                <li class="">
                    <a asp-area="Admin" asp-controller="Table" asp-action="Tables" class="text-decoration-none p-3 text-dark d-flex align-items-center">
                        <i class="bi px-2 fs-3 me-3 bi-table text-primary"></i> Tables
                    </a>
                </li>
                <li class="">
                    <a asp-area="Admin" asp-controller="Category" asp-action="Categories" class="text-decoration-none p-3 text-dark d-flex align-items-center">
                        <i class="bi px-2 fs-3 me-3 bi-funnel-fill text-primary"></i> Categories
                    </a>
                </li>
                <li class="">
                    <a asp-area="Admin" asp-controller="Guest" asp-action="Customers" class="text-decoration-none p-3 text-dark d-flex align-items-center">
                        <i class="bi px-2 fs-3 me-3 text-primary bi-person-lines-fill"></i> Customers
                    </a>
                </li>
            </ul>
        </aside>

        <!-- Main content -->
        <section class="position-absolute mainContent top-0 end-0" style="width: 80%">
            <!-- Header -->
            <div class="bg-light shadow-sm p-3 d-flex justify-content-between align-items-center">
                <div class="d-flex align-items-stretch flex-nowrap" style="width: 30%;">
                    <span class="input-group-text" id="addon-wrapping">
                        <i class="bi bi-search"></i>
                    </span>
                    <input type="text" class="form-control" placeholder="Username" aria-label="Username" aria-describedby="addon-wrapping">
                </div>
                <a href="@Url.Action("Logout", "Auth")" class="btn btn-sm btn-outline-danger">
                    Logout
                </a>
            </div>

            <!-- Body content -->
            <div class="container-fluid py-4 bg-white">
                @RenderBody()
            </div>
        </section>
    </main>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
