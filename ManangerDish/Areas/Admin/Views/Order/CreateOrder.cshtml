    @model CreateOrderRequest
    @{
        ViewData["Title"] = "Create Order";
        ViewData["Message"] = "Create Order";
        List<Dish> Dishes = ViewBag.Dishes;
    }

    <div class="container py-4">
        <h1 class="mb-4">Create New Order</h1>

        <div class="p-4 bg-light shadow-sm rounded">
            <form method="post" id="orderForm">
                <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                <!-- 1. Table Selection -->
                <h4 class="mb-3 border-bottom pb-2">1. Select Table</h4>
                <div class="row mb-4">
                    <div class="col-md-6 mb-3">
                        <label asp-for="TableId" class="form-label">Table Number</label>
                        <select asp-for="TableId" id="tableSelect" class="form-select" asp-items="ViewBag.TablesSelect" required>
                            <option value="">-- Select Table --</option>
                        </select>
                        <span asp-validation-for="TableId" class="text-danger"></span>
                    </div>
                </div>

                <!-- 2. Guest Information -->
                <h4 class="mb-3 border-bottom pb-2">2. Guest Information</h4>
                <div class="row mb-4">
                    <div class="col-12 mb-3">
                        <div class="form-check form-check-inline">
                            <input class="form-check-input" type="radio" name="guestOption" id="existingGuest" value="existing" checked>
                            <label class="form-check-label" for="existingGuest">Select Existing Guest</label>
                        </div>
                        <div class="form-check form-check-inline">
                            <input class="form-check-input" type="radio" name="guestOption" id="newGuest" value="new">
                            <label class="form-check-label" for="newGuest">Create New Guest</label>
                        </div>
                    </div>

                    <!-- Existing Guest Section -->
                    <div class="col-md-6 mb-3" id="existingGuestSection">
                        <label for="guestSelect" class="form-label">Select Guest</label>
                    <select id="guestSelect" name="GuestId" class="form-select" asp-items="ViewBag.CumstomerSelect">
                            <option value="">-- Select Guest --</option>
                        </select>
                        <span class="text-danger" id="guestSelectError"></span>
                    </div>

                    <!-- New Guest Section -->
                    <div class="col-md-12 mb-3 d-none" id="newGuestSection">
                        <div class="card">
                            <div class="card-body">
                                <div class="row">
                                    <div class="col-md-6 mb-3">
                                        <label for="NewGuestName" class="form-label">Guest Name <span class="text-danger">*</span></label>
                                        <input type="text" id="NewGuestName" name="NewGuestName" class="form-control" placeholder="Enter guest name" maxlength="100">
                                        <span class="text-danger" id="newGuestNameError"></span>
                                    </div>
                                    <div class="col-md-6 mb-3">
                                        <label for="NewGuestPhone" class="form-label">Phone Number <span class="text-danger">*</span></label>
                                        <input type="tel" id="NewGuestPhone" name="NewGuestPhone" class="form-control" placeholder="Enter phone number" maxlength="15">
                                        <span class="text-danger" id="newGuestPhoneError"></span>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- 3. Menu Selection -->
                <h4 class="mb-3 border-bottom pb-2">3. Select Dishes</h4>
                <div class="row mb-4">

                    <!-- Dishes Grid -->
                    <div class="col-12">
                        <div class="card">
                            <div class="card-body">
                                @if (ViewBag.Dishes != null && Dishes.Count > 0)
                                {
                                    <div class="row" id="dishesContainer">
                                        @for (var i = 0; i < Dishes.Count; i++)
                                        {
                                            <div class="col-lg-3 col-md-4 col-sm-6 mb-4 dish-item"
                                                 data-name="@Dishes[i].Name.ToLower()"
                                                 data-category="@Dishes[i].CategoryId"
                                                 data-price="@Dishes[i].Price">
                                                <div class="card h-100 dish-card">
                                                    <div class="position-relative">
                                                        <img src="@Dishes[i].Image" class="card-img-top" alt="@Dishes[i].Name"
                                                             style="height: 180px; object-fit: cover;">
                                                        <div class="position-absolute top-0 end-0 m-2">
                                                            <span class="badge bg-primary">@string.Format("{0:C0}", Dishes[i].Price)</span>
                                                        </div>
                                                    </div>
                                                    <div class="card-body d-flex flex-column">
                                                        <h6 class="card-title mb-2">@Dishes[i].Name</h6>
                                                        <p class="card-text small text-muted flex-grow-1">@Dishes[i].Description</p>

                                                        <!-- Hidden Fields -->
                                                        <input type="hidden" name="GuestOrder[@i].DishId" value="@Dishes[i].Id" />

                                                        <!-- Quantity Controls -->
                                                        <div class="mt-auto">
                                                            <div class="d-flex justify-content-between align-items-center">
                                                                <button type="button" class="btn btn-outline-secondary btn-sm quantity-btn"
                                                                        onclick="decrementQuantity(@i)" data-action="decrement">
                                                                    <i class="bi bi-dash"></i>
                                                                </button>
                                                            <input type="number" name="GuestOrder[@i].Quality"
                                                                       class="form-control text-center quantity-input"
                                                                       id="quantity_@i"
                                                                       value="0"
                                                                       min="0"
                                                                       max="99"
                                                                       style="max-width: 70px;"
                                                                       onchange="updateQuantity(@i)">
                                                                <button type="button" class="btn btn-outline-secondary btn-sm quantity-btn"
                                                                        onclick="incrementQuantity(@i)" data-action="increment">
                                                                    <i class="bi bi-plus"></i>
                                                                </button>
                                                            </div>
                                                        </div>
                                                    </div>
                                                </div>
                                            </div>
                                        }
                                    </div>
                                }
                                else
                                {
                                    <div class="alert alert-info text-center">
                                        <i class="bi bi-info-circle me-2"></i>
                                        No dishes available at the moment.
                                    </div>
                                }

                                <!-- No Results Message -->
                                <div id="noDishesMessage" class="alert alert-warning text-center d-none">
                                    <i class="bi bi-search me-2"></i>
                                    No dishes found matching your search criteria.
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                @* <!-- 4. Order Summary -->
                <div id="orderSummarySection" class="d-none">
                    <h4 class="mb-3 border-bottom pb-2">4. Order Summary</h4>
                    <div class="row mb-4">
                        <div class="col-12">
                            <div class="card">
                                <div class="card-header bg-light d-flex justify-content-between align-items-center">
                                    <h5 class="mb-0">Selected Items</h5>
                                    <span class="badge bg-primary" id="totalItemsCount">0 items</span>
                                </div>
                                <div class="card-body">
                                    <div id="orderSummaryItems"></div>
                                    <hr>
                                    <div class="d-flex justify-content-between align-items-center">
                                        <h5 class="mb-0">Total Amount:</h5>
                                        <h5 class="mb-0 text-primary" id="orderTotal">$0.00</h5>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
     *@
                <!-- Action Buttons -->
                <div class="d-flex justify-content-between mt-4">
                    <a asp-action="Orders" class="btn btn-secondary">
                        <i class="bi bi-arrow-left"></i> Back to Orders
                    </a>
                    <button type="submit" id="submitOrderBtn" class="btn btn-primary btn-lg">
                        <i class="bi bi-check-circle"></i> Create Order
                    </button>
                </div>
            </form>
        </div>
    </div>

    @section Scripts {
        <script>
            // Dish data for calculations
            const dishData = @Html.Raw(Json.Serialize(Dishes.Select(d => new { d.Id, d.Name, d.Price })));

            // Guest option toggle
            document.querySelectorAll('input[name="guestOption"]').forEach(radio => {
                radio.addEventListener('change', function() {
                    const isExisting = document.getElementById('existingGuest').checked;
                    document.getElementById('existingGuestSection').classList.toggle('d-none', !isExisting);
                    document.getElementById('newGuestSection').classList.toggle('d-none', isExisting);

                    // Clear errors
                    clearErrors();
                });
            });

            // Quantity control functions
            function incrementQuantity(index) {
                const input = document.getElementById(`quantity_${index}`);
                const currentValue = parseInt(input.value) || 0;
                if (currentValue < 99) {
                    input.value = currentValue + 1;
                }
            }

            function decrementQuantity(index) {
                const input = document.getElementById(`quantity_${index}`);
                const currentValue = parseInt(input.value) || 0;
                if (currentValue > 0) {
                    input.value = currentValue - 1;
                }
            }

       
        </script>

        @{
            await Html.RenderPartialAsync("_ValidationScriptsPartial");
        }
    }   