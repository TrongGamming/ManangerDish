@model CreateOrderRequest  
@{
    ViewData["Title"] = "Create Order";
    ViewData["Message"] = "Create Order";
	List<Dish> Dishes = ViewBag.Dishes;
}

<div class="container py-4">
    <h1 class="mb-4">Create New Order</h1>

    <div class="p-4 bg-light shadow-sm rounded">
        <form method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

            <h4 class="mb-3 border-bottom pb-2">1. Select Table</h4>
            <div class="row mb-4">
                <div class="col-md-6 mb-3">
                    <label asp-for="TableId" class="form-label">Table Number</label>
                    <select asp-for="TableId" id="tableSelect" class="form-select" asp-items="ViewBag.TablesSelect" required>
                        <option value="">-- Select Table --</option>
                    </select>
                    <span asp-validation-for="TableId" class="text-danger"></span>
                </div>
            </div>

            <h4 class="mb-3 border-bottom pb-2">2. Guest Information</h4>
            <div class="row mb-4">
                <div class="col-12 mb-3">
                    <div class="form-check form-check-inline">
                        <input class="form-check-input" type="radio" name="guestOption" id="existingGuest" value="existing" checked>
                        <label class="form-check-label" for="existingGuest">Select Existing Guest</label>
                    </div>
                    <div class="form-check form-check-inline">
                        <input class="form-check-input" type="radio" name="guestOption" id="newGuest" value="new">
                        <label class="form-check-label" for="newGuest">Create New Guest</label>
                    </div>
                </div>

                <div class="col-md-6 mb-3" id="existingGuestSection">
                    <label for="guestSelect" class="form-label">Select Guest</label>
                    <select id="guestSelect" name="GuestId" class="form-select" asp-items="ViewBag.CumstomerSelect">
                        <option value="">-- Select Guest --</option>
                    </select>
                    <span class="text-danger" id="guestSelectError"></span>
                </div>

                <div class="col-md-12 mb-3 d-none" id="newGuestSection">
                    <div class="card">
                        <div class="card-body">
                            <div class="row">
                                <div class="col-md-6 mb-3">
                                    <label for="NewGuestName" class="form-label">Guest Name</label>
                                    <input type="text" id="NewGuestName" name="NewGuestName" class="form-control" placeholder="Enter guest name">
                                    <span class="text-danger" id="newGuestNameError"></span>
                                </div>
                                <div class="col-md-6 mb-3">
                                    <label for="NewGuestPhone" class="form-label">Phone Number</label>
                                    <input type="tel" id="NewGuestPhone" name="NewGuestPhone" class="form-control" placeholder="Enter phone number" maxlength="10">
                                    <span class="text-danger" id="newGuestPhoneError"></span>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <h4 class="mb-3 border-bottom pb-2">3. Select Dishes</h4>
            <div class="row mb-4">
                @* <div class="col-12 mb-3">
                    <div class="input-group">
                        <span class="input-group-text"><i class="bi bi-search"></i></span>
                        <input type="text" id="dishSearchInput" class="form-control" placeholder="Search for dishes by name, category, or description">
                    </div>
                </div> *@

                <div class="col-12 mb-3">
                    <div class="card">
                        @* <div class="card-header bg-light">
                            <div class="row">
                                <div class="col-md-3">
                                    <select id="categoryFilter" asp-items=@ViewBag.CategoriesSelect class="form-select form-select-sm">
                                        <option value="">All Categories</option>

                                    </select>
                                </div>
                                <div class="col-md-3">
                                    <select id="priceFilter" class="form-select form-select-sm">
                                        <option value="">All Prices</option>
                                        <option value="low">Low to High</option>
                                        <option value="high">High to Low</option>
                                    </select>
                                </div>
                            </div>
                        </div> *@
                        <div class="card-body">
                            @if (ViewBag.Dishes != null)
                            {
                                <div class="row" id="dishesContainer">
                                    @for(var i = 0; i < Dishes.Count; i++)
                                    {
                                        <div class="col-lg-3 col-md-4 col-sm-6 mb-3">
                                            <div class="card h-100">
                                                <img src="@Dishes[i].Image" class="card-img-top" alt="${dish.name}" style="height: 150px; object-fit: cover;">
                                                <div class="card-body">
                                                    <h6 class="card-title">@Dishes[i].Name</h6>
                                                    <input type="hidden" name="GuestOrder[@i].DishId" value="@Dishes[i].Id" />
													<input type="hidden" name="GuestOrder[@i].Quality" value="1" />
                                                    <p class="card-text small text-muted">@Dishes[i].Description</p>
                                                    <span class="fw-bold">@string.Format("{0:C0}", Dishes[i].Price)</span>
                                                    <div class="justify-content-between d-flex align-items-center ">
                                                        <span onclick="decrementInputQuality()" class="btn btn-sm btn-primary">=</span>
                                                        <input type="number" name="GuestOrder[@i].Quality" style="min-width: 50%" class="w-100 text-center" id="inputQuality" value="0" />
                                                        <span onclick="incrementInputQuality()" class="btn btn-sm btn-primary">+</span>
                                                    </div>
                                                </div>
                                            </div>
                                        </div>
                                    }
                                </div>
                            }
                            else
                            {
                             <div id="noDishesMessage" class="alert alert-info d-none">
                                <i class="bi bi-info-circle me-2"></i> No dishes found matching your criteria.
                            </div>
                            }
                        </div>
                    </div>
                </div>
            </div>

            @*< h4 class="mb-3 border-bottom pb-2">4. Order Summary</h4>
            <div class="row mb-4">
                <div class="col-12">
                    <div class="card">
                        <div class="card-header bg-light d-flex justify-content-between align-items-center">
                            <h5 class="mb-0">Selected Dishes</h5>
                            <span class="badge bg-primary" id="totalItemsCount">0 items</span>
                        </div>
                        <div class="card-body p-0">
                            <div class="table-responsive">
                                <table class="table table-hover mb-0">
                                    <thead class="table-light">
                                        <tr>
                                            <th>Dish</th>
                                            <th>Price</th>
                                            <th width="120">Quantity</th>
                                            <th>Subtotal</th>
                                            <th width="50">Action</th>
                                        </tr>
                                    </thead>
                                    <tbody id="orderItemsContainer">
                                        <tr id="noItemsRow">
                                            <td colspan="5" class="text-center py-3">No items added to order yet</td>
                                        </tr>
                                    </tbody>
                                    <tfoot class="table-light">
                                        <tr>
                                            <th colspan="3" class="text-end">Total:</th>
                                            <th id="orderTotal">$0.00</th>
                                            <th></th>
                                        </tr>
                                    </tfoot>
                                </table>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <div id="selectedDishesContainer">
                <!-- Hidden inputs for selected dishes will be added here -->
            </div> *@

            <div class="d-flex justify-content-end mt-4">
                <a asp-action="Orders" class="btn btn-secondary me-2">Cancel</a>
                <button type="submit" id="submitOrderBtn" class="btn btn-primary">
                    <i class="bi bi-save"></i> Create Order
                </button>
            </div>
        </form>
    </div>
</div>

@section Scripts {

    <script>
        document.querySelectorAll('input[name="guestOption"]').forEach(radio => {
            radio.addEventListener('change', function() {
                const isExisting = document.getElementById('existingGuest').checked;
                document.getElementById('existingGuestSection').classList.toggle('d-none', !isExisting);
                document.getElementById('newGuestSection').classList.toggle('d-none', isExisting);
                
                document.getElementById('guestSelectError').textContent = '';
                document.getElementById('newGuestNameError').textContent = '';
                document.getElementById('newGuestPhoneError').textContent = '';
            });
        });

        // Hangdler input quality
		const inputQuality = document.querySelector('#inputQuality');

        const incrementInputQuality = () => {
			inputQuality.value = parseInt(inputQuality.value) + 1;
        }

        const decrementInputQuality = () => {
            if (parseInt(inputQuality.value) > 0) {
				inputQuality.value = parseInt(inputQuality.value) - 1;
			}
        }
</script>
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}