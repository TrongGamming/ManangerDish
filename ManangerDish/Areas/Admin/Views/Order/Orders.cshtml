@model List<OrderDetail>
@{
    ViewData["Title"] = "Order";
    ViewData["Message"] = "Order";
    var inforOrder = ViewBag.InforOrder;
    var listTableId = ViewBag.ListTableId as List<int>;
    var jsonOptions = new JsonSerializerOptions
            {
                ReferenceHandler = ReferenceHandler.IgnoreCycles
            };
    var serializedData = JsonSerializer.Serialize(listTableId, jsonOptions);
}

<div class="container-fluid py-4">
    <!-- Page Header -->
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1 class="h2 mb-0">List Order</h1>
        <a class="btn btn-primary d-flex align-items-center" asp-controller="Order" asp-action="CreateOrder">
            <i class="bi bi-plus-circle me-2"></i> Create New Order
        </a>
    </div>

    <!-- Table Status Overview -->
    <div class="bg-light p-4 shadow-sm rounded mb-4">
        <h5 class="mb-3 border-bottom pb-2">Tables Overview</h5>
        <div class="row row-cols-1 row-cols-md-3 row-cols-lg-4 g-3">
            @foreach (var item in inforOrder)
            {
                <div class="col">
                    <div class="card h-100 bg-white rounded shadow-sm  transition">
                        <div class="card-body">
                            <div class="d-flex justify-content-between align-items-center mb-3">
                                <h5 class="card-title mb-0">Table @item.TableNumber</h5>
                                <span class="badge bg-info rounded-pill">@item.QualityGuest Guests</span>
                            </div>
                            <div class="row g-2 flex-xl-column text-center">
                                <div class="col-6 col-xl-12">
                                    <div class="p-2 bg-light rounded">
                                        <div class="d-flex align-items-center justify-content-center">
                                            <i class="bi bi-hourglass-split me-1 text-warning"></i>
                                            <span>@item.PedingOrder</span>
                                        </div>
                                        <small class="text-muted">Pending</small>
                                    </div>
                                </div>
                                <div class="col-6 col-xl-12">
                                    <div class="p-2 bg-light rounded">
                                        <div class="d-flex align-items-center justify-content-center">
                                            <i class="bi bi-gear me-1 text-primary"></i>
                                            <span>@item.ProcessingOrder</span>
                                        </div>
                                        <small class="text-muted">Processing</small>
                                    </div>
                                </div>
                                <div class="col-6 col-xl-12">
                                    <div class="p-2 bg-light rounded">
                                        <div class="d-flex align-items-center justify-content-center">
                                            <i class="bi bi-check-circle me-1 text-success"></i>
                                            <span>@item.CompletedOrder</span>
                                        </div>
                                        <small class="text-muted">Completed</small>
                                    </div>
                                </div>
                                <div class="col-6 col-xl-12">
                                    <div class="p-2 bg-light rounded">
                                        <div class="d-flex align-items-center justify-content-center">
                                            <i class="bi bi-x-circle me-1 text-danger"></i>
                                            <span>@item.CancelledsOrder</span>
                                        </div>
                                        <small class="text-muted">Cancelled</small>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    </div>

    <!-- Filter Section -->
    <div class="mb-4">
        <button class="btn btn-outline-secondary w-100 mb-3 d-md-none" type="button" data-bs-toggle="collapse" data-bs-target="#filterCollapse" aria-expanded="false" aria-controls="filterCollapse">
            <i class="bi bi-funnel-fill me-2"></i> Show Filter Options
        </button>

        <form method="get">
            <div class="collapse d-md-block" id="filterCollapse">
                <div class="p-4 bg-light rounded shadow-sm mb-3">
                    <h5 class="mb-3 border-bottom pb-2">Filter Orders</h5>

                    <div class="row g-3">
                        <div class="col-12 col-md-4">
                            <label for="statusFilter" class="form-label">Status</label>
                            <select asp-items="@Html.GetEnumSelectList<OrderStatus>()" class="form-select" id="statusFilter" name="Status">
                                <option value="">---- All ----</option>
                            </select>
                        </div>

                        <div class="col-12">
                            <label for="searchInput" class="form-label">Search</label>
                            <div class="input-group">
                                <span class="input-group-text"><i class="bi bi-search"></i></span>
                                <input type="text" class="form-control" id="searchInput" name="q" placeholder="Search by dish, guest or table" value="@ViewBag.search">
                            </div>
                        </div>
                    </div>

                    <div class="row mt-3">
                        <div class="col-12 col-md-6 mb-2 mb-md-0">
                            <button class="btn btn-primary w-100" type="submit">
                                <i class="bi bi-funnel-fill me-2"></i> Apply Filters
                            </button>
                        </div>
                        <div class="col-12 col-md-6">
                            <a href="@Url.Action("Orders", "Order")" class="btn btn-outline-secondary w-100">
                                <i class="bi bi-x-circle me-2"></i> Clear Filters
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        </form>
    </div>

    <!-- Orders List -->
    <div class="bg-light p-4 shadow-sm rounded">
        <h5 class="mb-3 border-bottom pb-2">Order Details</h5>

        <!-- Header Row - Desktop Only -->
        <div class="row fw-bold pb-2 border-bottom d-none d-lg-flex text-center mb-3">
            <div class="col-lg-2">Guest Name</div>
            <div class="col-lg-2">Table Number</div>
            <div class="col-lg-4">Dish</div>
            <div class="col-lg-2">Handler</div>
            <div class="col-lg-2">Actions</div>
        </div>

        <!-- Order Items -->
        @foreach (var item in Model)
        {
            <div class="card mb-3 shadow-sm  transition">
                <div class="card-body">
                    <!-- Desktop View -->
                    <div class="row d-none d-lg-flex align-items-center text-center">
                        <div class="col-lg-2">@(item.Guest?.Name ?? "Null")</div>
                        <div class="col-lg-2">@(item.Order?.Table?.Number)</div>
                        <div class="col-lg-4">
                            <div class="d-flex align-items-center justify-content-center">
                                <img src="@(item.Dish.Image)" width="50" height="50" class="rounded me-3" style="object-fit: cover" alt="@item.Dish.Name" />
                                <div class="text-start">
                                    <p class="mb-0"><strong>@item.Dish.Name</strong></p>
                                    <p class="mb-0">@string.Format("{0:C0}", item.Dish.Price) × @item.Quantity = @string.Format("{0:C0}", item.Dish.Price * item.Quantity)</p>
                                </div>
                            </div>
                        </div>
                        <div class="col-lg-2">@(item.Handler?.Name ?? "Null")</div>
                        <div class="col-lg-2">
                            <div class="d-flex justify-content-around">
                                <a href="@Url.Action("DetailsOrder", "Order", new { id = item.Id })" class="btn btn-sm btn-outline-info">
                                    <i class="bi bi-info-circle"></i>
                                </a>
                                <a href="@Url.Action("EditOrder", "Order", new { id = item.Id })" class="btn btn-sm btn-outline-primary">
                                    <i class="bi bi-pencil-square"></i>
                                </a>
                                <a href="@Url.Action("DeleteOrder", "Order", new { id = item.Id })" class="btn btn-sm btn-outline-danger">
                                    <i class="bi bi-trash"></i>
                                </a>
                            </div>
                        </div>
                    </div>

                    <!-- Mobile View -->
                    <div class="d-lg-none">
                        <div class="d-flex align-items-center mb-3">
                            <img src="@item.Dish.Image" width="60" height="60" class="rounded me-3" style="object-fit: cover" alt="@item.Dish.Name" />
                            <div>
                                <h5 class="mb-0">@item.Dish.Name</h5>
                                <p class="mb-0">@string.Format("{0:C0}", item.Dish.Price) × @item.Quantity</p>
                                <p class="text-primary fw-bold mb-0">@string.Format("{0:C0}", item.Dish.Price * item.Quantity)</p>
                            </div>
                        </div>

                        <div class="row mb-3 g-2">
                            <div class="col-6">
                                <div class="bg-light p-2 rounded">
                                    <small class="text-muted d-block">Guest</small>
                                    <strong>@(item.Guest?.Name ?? "Null")</strong>
                                </div>
                            </div>
                            <div class="col-6">
                                <div class="bg-light p-2 rounded">
                                    <small class="text-muted d-block">Table</small>
                                    <strong>@(item.Order?.Table?.Number)</strong>
                                </div>
                            </div>
                            <div class="col-12">
                                <div class="bg-light p-2 rounded">
                                    <small class="text-muted d-block">Handler</small>
                                    <strong>@(item.Handler?.Name ?? "Null")</strong>
                                </div>
                            </div>
                        </div>

                        <div class="d-flex justify-content-end gap-2">
                            <a href="@Url.Action("DetailsOrder", "Order", new { id = item.Id })" class="btn btn-sm btn-outline-info">
                                <i class="bi bi-info-circle me-1"></i> Details
                            </a>
                            <a href="@Url.Action("EditOrder", "Order", new { id = item.Id })" class="btn btn-sm btn-outline-primary">
                                <i class="bi bi-pencil-square me-1"></i> Edit
                            </a>
                            <a href="@Url.Action("DeleteOrder", "Order", new { id = item.Id })" class="btn btn-sm btn-outline-danger">
                                <i class="bi bi-trash me-1"></i> Delete
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        }

        <!-- Pagination -->
        <div class="mt-4 d-flex justify-content-center">
            <pagination page-model="@ViewBag.Model"></pagination>
        </div>
    </div>
</div>

<!-- Scripts -->
@section Scripts {
    <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/6.0.0/signalr.min.js"></script>
    <script>
        const ListTableId = @Html.Raw(serializedData);

        const connection = new signalR.HubConnectionBuilder()
            .withUrl("/OrderHub")
            .build();

        connection.on("Refresh", function (message) {
            window.location.reload();
        });

        connection.start().then(function () {
            console.log("Connected to SignalR Hub");
            if (Array.isArray(ListTableId)) {
                ListTableId.forEach(function (tableId) {
                    connection.invoke("AddToGroup", tableId.toString()).catch(function (err) {
                        console.error(`Error invoking AddToGroup for table ${tableId}: `, err.toString());
                    });
                });
            } else {
                console.error("ListTableId is not an array:", ListTableId);
            }
        }).catch(function (err) {
            console.error("Error connecting to SignalR: ", err.toString());
        });

        // Search functionality for mobile
        document.getElementById('searchInput')?.addEventListener('input', function(e) {
            const searchText = e.target.value.toLowerCase();
            const orderCards = document.querySelectorAll('.card');

            orderCards.forEach(card => {
                const cardText = card.textContent.toLowerCase();
                if (cardText.includes(searchText)) {
                    card.style.display = 'block';
                } else {
                    card.style.display = 'none';
                }
            });
        });
    </script>
}