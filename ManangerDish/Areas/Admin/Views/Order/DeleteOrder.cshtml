@model ManagerDish.Models.OrderDetail
@{
    ViewData["Title"] = "Delete Order Detail";
    ViewData["Message"] = "Delete Order Detail";
}
<div class="container py-4">
    <h1 class="mb-4">Delete Order Detail</h1>
    <div class="alert alert-danger">
        <h4>Are you sure you want to delete this order detail?</h4>
        <p>This action cannot be undone.</p>
    </div>
    <div class="p-4 bg-light shadow-sm rounded">
        <div class="row">
            <div class="col-md-4 mb-4">
                <img src="@(Model.Dish != null && !string.IsNullOrEmpty(Model.Dish.Image) ? Model.Dish.Image : "/images/dishes/default-dish.png")"
                     alt="@(Model.Dish?.Name ?? "Dish")" class="img-fluid rounded" style="width: 100%; max-height: 250px; object-fit: cover;" />
            </div>
            <div class="col-md-8">
                <dl class="row">
                    <dt class="col-sm-3">Order Detail ID</dt>
                    <dd class="col-sm-9">@Model.Id</dd>

                    <dt class="col-sm-3">Dish</dt>
                    <dd class="col-sm-9">@(Model.Dish?.Name ?? "N/A")</dd>

                    <dt class="col-sm-3">Quantity</dt>
                    <dd class="col-sm-9">@Model.Quantity</dd>

                    <dt class="col-sm-3">Order</dt>
                    <dd class="col-sm-9">@(Model.OrderId.HasValue ? $"Order #{Model.OrderId}" : "No Order")</dd>

                    <dt class="col-sm-3">Guest</dt>
                    <dd class="col-sm-9">@(Model.Guest?.Name ?? "N/A")</dd>

                    <dt class="col-sm-3">Handler</dt>
                    <dd class="col-sm-9">@(Model.Handler?.Name ?? "Unassigned")</dd>

                    <dt class="col-sm-3">Status</dt>
                    <dd class="col-sm-9">
                        <span class="badge @(GetStatusBadgeClass(Model.Status))">@Model.Status</span>
                    </dd>

                    <dt class="col-sm-3">Created</dt>
                    <dd class="col-sm-9">@Model.CreatedAt.ToString("MMM dd, yyyy HH:mm")</dd>

                    <dt class="col-sm-3">Last Updated</dt>
                    <dd class="col-sm-9">@Model.UpdatedAt.ToString("MMM dd, yyyy HH:mm")</dd>
                </dl>

                @if (Model.Status != OrderStatus.Completed)
                {
                    <div class="alert alert-warning">
                        <strong>Warning:</strong> This order detail has not been completed.
                        Deleting it may affect order tracking and billing.
                    </div>
                }
            </div>
        </div>
        <form method="post" class="mt-4 pt-3 border-top">
            <input type="hidden" asp-for="Id" />
            <div class="d-flex justify-content-end">
                <a asp-controller="OrderDetail" asp-action="Index" class="btn btn-secondary me-2">Cancel</a>
                <button type="submit" class="btn btn-danger">
                    <i class="bi bi-trash"></i> Delete Order Detail
                </button>
            </div>
        </form>
    </div>
</div>

@functions {
    string GetStatusBadgeClass(OrderStatus status)
    {
        return status switch
        {
            OrderStatus.Pending => "bg-warning",
            OrderStatus.Processing => "bg-info",
            OrderStatus.Completed => "bg-success",
            OrderStatus.Cancelled => "bg-danger",
            _ => "bg-secondary"
        };
    }
}