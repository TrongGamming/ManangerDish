@model EditOrderRequest
@{
    ViewData["Title"] = "Edit Order";
    ViewData["Message"] = "Edit Order";
    List<Dish> Dishes = ViewBag.Dishes;
    OrderDetail orderDetail = ViewBag.OrderDetails;
}

<div class="container py-4">
    <h1 class="mb-4">Edit Order</h1>

    <div class="p-4 bg-light shadow-sm rounded">
        <form method="post">
            <input type="hidden" name="OrderId" value="@ViewBag.OrderId" />

            <h4 class="mb-3 border-bottom pb-2">1. Current Order Items</h4>
            <div class="row mb-4">
                <div class="col-12">
                    <div class="card">
                        <div class="card-body">
                            <div class="row" id="currentOrderContainer">
                                    <div class="col-12 mb-3 border-bottom pb-3">
                                        <div class="d-flex justify-content-between align-items-center">
                                            <div>
                                                <h6 class="mb-1">@orderDetail.Dish.Name</h6>
                                                <small class="text-muted">
                                                    @string.Format("{0:C0}", orderDetail.Dish.Price) x @orderDetail.Quantity
                                                </small>
                                            </div>
                                            <span class="fw-bold">
                                                @string.Format("{0:C0}", orderDetail.Quantity * orderDetail.Dish.Price)
                                            </span>
                                        </div>
                                    </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <h4 class="mb-3 border-bottom pb-2">2. Modify Order</h4>
            <div class="row mb-4">
                <div class="col-12 mb-3">
                    <div class="card">
                        <div class="card-body">
                            @if (ViewBag.Dishes != null)
                            {
                                <div class="row" id="dishesContainer">
                                    @for (var i = 0; i < Dishes.Count; i++)
                                    {
                                        <div class="col-lg-3 col-md-4 col-sm-6 mb-3">
                                            <div class="card h-100">
                                                <img src="@Dishes[i].Image" class="card-img-top" alt="@Dishes[i].Name" style="height: 150px; object-fit: cover;">
                                                <div class="card-body">
                                                    <h6 class="card-title">@Dishes[i].Name</h6>
                                                    <input type="hidden" name="GuestOrder[@i].DishId" value="@Dishes[i].Id" />
                                                    <p class="card-text small text-muted">@Dishes[i].Description</p>
                                                    <span class="fw-bold">@string.Format("{0:C0}", Dishes[i].Price)</span>
                                                    <div class="d-flex justify-content-between align-items-center mt-2">
                                                        <button type="button" onclick="decrementQuantity(this)" class="btn btn-sm btn-outline-secondary">
                                                            <i class="bi bi-dash"></i>
                                                        </button>
                                                        <input type="number"
                                                               name="GuestOrder[@i].Quantity"
                                                               class="form-control form-control-sm text-center quantity-input"
                                                               value="0"
                                                               min="0"
                                                               style="width: 70px;" />
                                                        <button type="button" onclick="incrementQuantity(this)" class="btn btn-sm btn-outline-secondary">
                                                            <i class="bi bi-plus"></i>
                                                        </button>
                                                    </div>
                                                </div>
                                            </div>
                                        </div>
                                    }
                                </div>
                            }
                            else
                            {
                                <div class="alert alert-info text-center">
                                    <i class="bi bi-info-circle me-2"></i> No dishes available for modification
                                </div>
                            }
                        </div>
                    </div>
                </div>
            </div>

            <div class="d-flex justify-content-end mt-4">
                <a asp-action="Orders" class="btn btn-secondary me-2">Cancel</a>
                <button type="submit" id="submitOrderBtn" class="btn btn-primary">
                    <i class="bi bi-save"></i> Update Order
                </button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <script>
        function incrementQuantity(element) {
            const input = element.previousElementSibling;
            input.value = parseInt(input.value) + 1;
            updateTotalDisplay();
        }

        // Quantity decrement function
        function decrementQuantity(element) {
            const input = element.nextElementSibling;
            if (parseInt(input.value) > 0) {
                input.value = parseInt(input.value) - 1;
                updateTotalDisplay();
            }
        }

        // Optional: Update total display
        function updateTotalDisplay() {
            let total = 0;
            const dishes = document.querySelectorAll('#dishesContainer .card');

            dishes.forEach(dish => {
                const priceElement = dish.querySelector('.fw-bold');
                const quantityInput = dish.querySelector('.quantity-input');

                const price = parseFloat(priceElement.textContent.replace('₫', '').trim());
                const quantity = parseInt(quantityInput.value);

                total += price * quantity;
            });

            // Optional: If you want to show a total (uncomment if needed)
            // document.getElementById('orderTotal').textContent = `₫${total.toFixed(0)}`;
        }

        // Prevent negative quantities
        document.addEventListener('input', function(e) {
            if (e.target.classList.contains('quantity-input')) {
                if (parseInt(e.target.value) < 0) {
                    e.target.value = 0;
                }
            }
        });
    </script>

    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}