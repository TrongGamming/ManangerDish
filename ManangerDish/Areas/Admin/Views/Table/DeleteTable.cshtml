@model ManagerDish.Models.DTO.EditTableRequest
@{
    ViewData["Title"] = "Delete Table";
    ViewData["Message"] = "Delete Table";
}
<div class="container py-4">
    <h1 class="mb-4">Delete Table</h1>
    <div class="alert alert-danger">
        <h4>Are you sure you want to delete this table?</h4>
        <p>This action cannot be undone.</p>
    </div>
    <div class="p-4 bg-light shadow-sm rounded">
        <div class="row">
            <div class="col-md-12">
                <dl class="row">
                    <dt class="col-sm-3">Table ID</dt>
                    <dd class="col-sm-9">@Model.Id</dd>

                    <dt class="col-sm-3">Capacity</dt>
                    <dd class="col-sm-9">@Model.Capicity</dd>

                    <dt class="col-sm-3">Status</dt>
                    <dd class="col-sm-9">
                        <span class="badge @(Model.Status == TableStatus.Available ? "bg-success" : "bg-warning")">
                            @Model.Status
                        </span>
                    </dd>

                    <dt class="col-sm-3">Table Token</dt>
                    <dd class="col-sm-9">
                        <code>@Model.Token</code>
                    </dd>
                </dl>

                <div class="alert alert-warning">
                    <strong>Warning:</strong> Deleting this table will remove it from the table management system.
                    @if (Model.Status == TableStatus.Reserved)
                    {
                        <p class="mt-2 mb-0">This table is currently <strong>reserved</strong>. Deleting it may disrupt existing reservations.</p>
                    }
                </div>
            </div>
        </div>
        <form method="post" class="mt-4 pt-3 border-top">
            <input type="hidden" asp-for="Id" />
            <div class="d-flex justify-content-end">
                <a asp-controller="Table" asp-action="Index" class="btn btn-secondary me-2">Cancel</a>
                <button type="submit" class="btn btn-danger">
                    <i class="bi bi-trash"></i> Delete Table
                </button>
            </div>
        </form>
    </div>
</div>