@model List<Table>
@{
    ViewData["Title"] = "Tables Management";
    ViewData["Message"] = "Table List";
}

<div class="container-fluid py-4">
    <!-- Page Header -->
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1 class="h2 mb-0">Tables Management</h1>
        <a class="btn btn-primary d-flex align-items-center" asp-controller="Table" asp-action="CreateTable">
            <i class="bi bi-plus-circle me-2"></i> Create New Table
        </a>
    </div>

    <!-- Filter Section -->
    <div class="mb-4">
        <button class="btn btn-outline-secondary w-100 mb-3 d-md-none" type="button" data-bs-toggle="collapse" data-bs-target="#filterCollapse" aria-expanded="false" aria-controls="filterCollapse">
            <i class="bi bi-funnel-fill me-2"></i> Show Filter Options
        </button>

        <form method="get">
            <div class="collapse d-md-block" id="filterCollapse">
                <div class="p-4 bg-light rounded shadow-sm mb-3">
                    <h5 class="mb-3 border-bottom pb-2">Filter Tables</h5>

                    <div class="row g-3">
                        <div class="col-12 col-md-3">
                            <label for="statusFilter" class="form-label">Status</label>
                            <select asp-items="@Html.GetEnumSelectList<TableStatus>()" class="form-select" id="statusFilter" name="Status">
                                <option value="">---- All Status ----</option>
                            </select>
                        </div>

                        <div class="col-12 col-md-3">
                            <label for="capacityFilter" class="form-label">Capacity</label>
                            <select class="form-select" id="capacityFilter" name="Capacity">
                                <option value="">---- All Capacities ----</option>
                                @for (int i = 1; i <= 10; i++)
                                {
                                    <option value="@i">@i Person@(i > 1 ? "s" : "")</option>
                                }
                            </select>
                        </div>

                        <div class="col-12 col-md-6">
                            <label for="searchInput" class="form-label">Search</label>
                            <div class="input-group">
                                <span class="input-group-text"><i class="bi bi-search"></i></span>
                                <input type="text" class="form-control" id="searchInput" name="q" placeholder="Search by table number or token" value="@ViewBag.search">
                            </div>
                        </div>
                    </div>

                    <div class="row mt-3">
                        <div class="col-12 col-md-6 mb-2 mb-md-0">
                            <button class="btn btn-primary w-100" type="submit">
                                <i class="bi bi-funnel-fill me-2"></i> Apply Filters
                            </button>
                        </div>
                        <div class="col-12 col-md-6">
                            <a href="@Url.Action("Tables", "Table")" class="btn btn-outline-secondary w-100">
                                <i class="bi bi-x-circle me-2"></i> Clear Filters
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        </form>
    </div>

    <!-- Table List -->
    <div class="bg-light p-4 shadow-sm rounded">
        <h5 class="mb-3 border-bottom pb-2">Table Details</h5>

        <!-- Header Row - Desktop Only -->
        <div class="row fw-bold pb-2 border-bottom d-none d-lg-flex text-center mb-3">
            <div class="col-lg-2">Table Number</div>
            <div class="col-lg-2">Status</div>
            <div class="col-lg-3">QR Code</div>
            <div class="col-lg-3">Link Action</div>
            <div class="col-lg-2">Actions</div>
        </div>

        <!-- Tables Items -->
        @foreach (var table in Model)
        {
            var guestPageUrl = @Url.Action("Guest", "Table", new { area = "Admin", token = table.Token })
            ;
            var qrCodeUrl = Url.Action("CreateQR", "QR", new { s = guestPageUrl });
            
            <div class="card mb-3 shadow-sm transition">
                <div class="card-body">
                    <!-- Desktop View -->
                    <div class="row d-none d-lg-flex align-items-center text-center">
                        <div class="col-lg-2">@(table.Number)</div>
                        <div class="col-lg-2">
                            <span class="badge @(table.Status == TableStatus.Available ? "bg-success" : table.Status == TableStatus.Occupied ? "bg-danger" : "bg-warning")">
                                @table.Status.ToString()
                            </span>
                        </div>
                        <div class="col-lg-3">
                            <img src="@qrCodeUrl" width="50" height="50" class="rounded me-3" style="object-fit: cover" alt="QR Code Table @table.Number" />
                        </div>
                        <div class="col-lg-3">
                            <a href="@guestPageUrl" class="text-truncate d-block">
                                @guestPageUrl
                            </a>
                        </div>
                        <div class="col-lg-2">
                            <div class="d-flex justify-content-around">
                                @* <a href="@Url.Action("Details", "Table", new { id = table.Number })" class="btn btn-sm btn-outline-info">
                                    <i class="bi bi-info-circle"></i>
                                </a> *@
                                <a href="@Url.Action("EditTable", "Table", new { id = table.Number })" class="btn btn-sm btn-outline-primary">
                                    <i class="bi bi-pencil-square"></i>
                                </a>
                                <a href="@Url.Action("DeleteTable", "Table", new { id = table.Number })" class="btn btn-sm btn-outline-danger">
                                    <i class="bi bi-trash"></i>
                                </a>
                            </div>
                        </div>
                    </div>

                    <!-- Mobile View -->
                    <div class="d-lg-none">
                        <div class="d-flex align-items-center mb-3">
                            <img src="@qrCodeUrl" width="60" height="60" class="rounded me-3" style="object-fit: cover" alt="QR Code Table @table.Number" />
                            <div>
                                <h5 class="mb-0">Table #@table.Number</h5>
                                <span class="badge @(table.Status == TableStatus.Available ? "bg-success" : table.Status == TableStatus.Occupied ? "bg-danger" : "bg-warning")">
                                    @table.Status.ToString()
                                </span>
                                <a href="@qrCodeUrl" class="d-block text-truncate" style="max-width: 250px;">
                                    @guestPageUrl
                                </a>
                            </div>
                        </div>

                        <div class="row mb-3 g-2">
                            <div class="col-12 col-md-6">
                                <div class="bg-light p-2 rounded">
                                    <small class="text-muted d-block">Capacity</small>
                                    <strong>@table.Capicity Person@(table.Capicity > 1 ? "s" : "")</strong>
                                </div>
                            </div>
                            <div class="col-12 col-md-6">
                                <div class="bg-light p-2 rounded">
                                    <small class="text-muted d-block">Token</small>
                                    <strong>@table.Token</strong>
                                </div>
                            </div>
                            <div class="col-12 col-md-6">
                                <div class="bg-light p-2 rounded">
                                    <small class="text-muted d-block">Created At</small>
                                    <strong>@table.CreatedAt.ToString("dd/MM/yyyy HH:mm")</strong>
                                </div>
                            </div>
                            <div class="col-12 col-md-6">
                                <div class="bg-light p-2 rounded">
                                    <small class="text-muted d-block">Updated At</small>
                                    <strong>@table.UpdatedAt.ToString("dd/MM/yyyy HH:mm")</strong>
                                </div>
                            </div>
                        </div>

                        <div class="d-flex justify-content-end gap-2">
                            @* <a href="@Url.Action("Details", "Table", new { id = table.Number })" class="btn btn-sm btn-outline-info">
                                <i class="bi bi-info-circle me-1"></i> Details
                            </a> *@
                            <a href="@Url.Action("EditTable", "Table", new { id = table.Number })" class="btn btn-sm btn-outline-primary">
                                <i class="bi bi-pencil-square me-1"></i> Edit
                            </a>
                            <a href="@Url.Action("DeleteTable", "Table", new { id = table.Number })" class="btn btn-sm btn-outline-danger">
                                <i class="bi bi-trash me-1"></i> Delete
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        }

        <!-- Pagination -->
        <div class="mt-4 d-flex justify-content-center">
            <pagination page-model="@ViewBag.Model"></pagination>
        </div>
    </div>
</div>