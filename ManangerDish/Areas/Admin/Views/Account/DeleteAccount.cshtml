@model ManagerDish.Models.DTO.EditAccountRequest
@{
    ViewData["Title"] = "Delete Account";
    ViewData["Message"] = "Delete Account";
}
<div class="container py-4">
    <h1 class="mb-4">Delete Account</h1>
    <div class="alert alert-danger">
        <h4>Are you sure you want to delete this account?</h4>
        <p>This action cannot be undone.</p>
    </div>
    <div class="p-4 bg-light shadow-sm rounded">
        <div class="row">
            <div class="col-md-4 mb-4">
                <img src="@(string.IsNullOrEmpty(Model.ImagePath) ? "/images/accounts/default-avatar.png" : Model.ImagePath)"
                     alt="@Model.UserName's Avatar" class="img-fluid rounded-circle" style="width: 250px; height: 250px; object-fit: cover;" />
            </div>
            <div class="col-md-8">
                <dl class="row">
                    <dt class="col-sm-3">Username</dt>
                    <dd class="col-sm-9">@Model.UserName</dd>

                    <dt class="col-sm-3">Email</dt>
                    <dd class="col-sm-9">@Model.Email</dd>

                    <dt class="col-sm-3">Role ID</dt>
                    <dd class="col-sm-9">@Model.RoleId</dd>
                </dl>
                <div class="alert alert-warning">
                    <strong>Warning:</strong> Deleting this account will permanently remove all associated data.
                </div>
            </div>
        </div>
        <form method="post" class="mt-4 pt-3 border-top">
            <input type="hidden" asp-for="Id" />
            <div class="d-flex justify-content-end">
                <a asp-controller="Account" asp-action="Index" class="btn btn-secondary me-2">Cancel</a>
                <button type="submit" class="btn btn-danger">
                    <i class="bi bi-trash"></i> Delete Account
                </button>
            </div>
        </form>
    </div>
</div>