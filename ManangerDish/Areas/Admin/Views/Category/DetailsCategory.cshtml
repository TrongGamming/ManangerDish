@model ManagerDish.Models.Category
@{
    ViewData["Title"] = "Category Details";
    ViewData["Message"] = "Category Details";
}

<div class="container py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1>Category Details</h1>
        <div>
            <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-primary">
                <i class="bi bi-pencil"></i> Edit
            </a>
            <a asp-action="Index" class="btn btn-secondary">
                <i class="bi bi-arrow-left"></i> Back to List
            </a>
        </div>
    </div>

    <div class="card shadow-sm">
        <div class="card-header bg-light">
            <h5 class="mb-0">@Model.Name</h5>
        </div>
        <div class="card-body">
            <div class="row">
                <div class="col-md-6 mb-3">
                    <div class="mb-3">
                        <strong>@Html.DisplayNameFor(model => model.Id):</strong>
                        <span class="ms-2">@Html.DisplayFor(model => model.Id)</span>
                    </div>
                    <div class="mb-3">
                        <strong>@Html.DisplayNameFor(model => model.Name):</strong>
                        <span class="ms-2">@Html.DisplayFor(model => model.Name)</span>
                    </div>
                    <div class="mb-3">
                        <strong>@Html.DisplayNameFor(model => model.Description):</strong>
                        <span class="ms-2">@Html.DisplayFor(model => model.Description)</span>
                    </div>
                </div>
                <div class="col-md-6 mb-3">
                    <div class="mb-3">
                        <strong>@Html.DisplayNameFor(model => model.CreatedAt):</strong>
                        <span class="ms-2">@Model.CreatedAt.ToString("yyyy-MM-dd HH:mm")</span>
                    </div>
                    <div class="mb-3">
                        <strong>Total Dishes:</strong>
                        <span class="ms-2">@(Model.Dishes?.Count() ?? 0)</span>
                    </div>
                </div>
            </div>
        </div>
    </div>

    @if (Model.Dishes != null && Model.Dishes.Any())
    {
        <div class="mt-4">
            <h3>Associated Dishes</h3>
            <div class="card shadow-sm">
                <div class="table-responsive">
                    <table class="table table-hover mb-0">
                        <thead class="table-light">
                            <tr>
                                <th>ID</th>
                                <th>Name</th>
                                <th>Price</th>
                                <th>Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var dish in Model.Dishes)
                            {
                                <tr>
                                    <td>@dish.Id</td>
                                    <td>@dish.Name</td>
                                    <td>@dish.Price.ToString("C")</td>
                                    <td>
                                        <a asp-controller="Dish" asp-action="Details" asp-route-id="@dish.Id" class="btn btn-sm btn-outline-info">
                                            <i class="bi bi-eye"></i> View
                                        </a>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    }
</div>