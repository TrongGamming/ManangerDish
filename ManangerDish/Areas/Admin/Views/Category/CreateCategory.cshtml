@model CreateCategoryRequest
@{
    ViewData["Title"] = "Edit Category";
    ViewData["Message"] = "Edit Category";
}

<div class="container py-4">
    <h1 class="mb-4">Create Category</h1>

    <div class="p-4 bg-light shadow-sm rounded">
        <form method="post" class="mt-2 py-4 border-top">
            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

            <div class="row">
                <div class="col-md-6 mb-3">
                    <label asp-for="Name" class="form-label">Category Name</label>
                    <input asp-for="Name" type="text" class="form-control" placeholder="Enter category name" maxlength="50" />
                    <span asp-validation-for="Name" class="text-danger"></span>
                    <small class="form-text text-muted">Maximum 50 characters</small>
                </div>

                <div class="col-md-6 mb-3">
                    <label asp-for="Description" class="form-label">Description</label>
                    <textarea asp-for="Description" class="form-control" rows="3" placeholder="Enter category description" maxlength="50"></textarea>
                    <span asp-validation-for="Description" class="text-danger"></span>
                    <small class="form-text text-muted">Maximum 50 characters</small>
                </div>
            </div>

            <div class="d-flex justify-content-end mt-4">
                <a asp-controller="Category" asp-action="Categories" class="btn btn-secondary me-2">Cancel</a>
                <button type="submit" class="btn btn-primary">
                    Create
                </button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}