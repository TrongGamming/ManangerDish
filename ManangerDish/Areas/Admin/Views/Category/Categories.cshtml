@model List<Category>
@{
    ViewData["Title"] = "Categories";
    ViewData["Message"] = "Categories";
}
<h1 class="my-4">Category Management</h1>

<div class="mb-4">
    <button class="btn btn-outline-secondary w-100 mb-3 d-md-none" type="button" data-bs-toggle="collapse" data-bs-target="#filterCollapse" aria-expanded="false" aria-controls="filterCollapse">
        <i class="bi bi-funnel-fill me-2"></i> Show Filter Options
    </button>

    <form method="get">
        <div class="collapse d-md-block" id="filterCollapse">
            <div class="p-4 bg-light shadow-sm mb-3">
                <h5 class="mb-3 border-bottom pb-2">Filter Categories</h5>

                <div class="row">
                    <div class="col-12 mb-3">
                        <label for="searchInput" class="form-label">Search</label>
                        <div class="input-group">
                            <span class="input-group-text"><i class="bi bi-search"></i></span>
                            <input type="text" class="form-control" id="searchInput" name="q" placeholder="Category Name or Description" value="@ViewBag.Search">
                        </div>
                    </div>
                </div>

                <div class="row mt-2">
                    <div class="col-12 col-md-6 mb-3">
                        <button class="btn btn-primary w-100" type="submit">
                            <i class="bi bi-funnel-fill me-2"></i> Apply Filters
                        </button>
                    </div>
                    <div class="col-12 col-md-6 mb-3">
                        <a href="@Url.Action("Categories", "Category")" class="btn btn-outline-secondary w-100">
                            <i class="bi bi-x-circle me-2"></i> Clear Filters
                        </a>
                    </div>
                </div>
            </div>
        </div>

        <div class="d-flex justify-content-end mb-3">
            <a class="btn btn-primary d-flex align-items-center justify-content-center" asp-controller="Category" asp-action="CreateCategory">
                <i class="bi bi-plus-circle me-2"></i> Create New Category
            </a>
        </div>
    </form>
</div>

<div class="p-4 bg-light shadow-sm d-none d-md-block">
    <div class="row fw-bold pb-2 border-bottom text-center">
        <div class="col-1">#</div>
        <div class="col-3">Name</div>
        <div class="col-4">Description</div>
        <div class="col-2">Dishes Count</div>
        <div class="col-2">Actions</div>
    </div>
    @foreach (var item in Model)
    {
        <div class="row py-2 border-bottom text-center align-items-center">
            <div class="col-1">@item.Id</div>
            <div class="col-3">@item.Name</div>
            <div class="col-4">@(item.Description.Length > 50 ? item.Description.Substring(0, 50) + "..." : item.Description)</div>
            <div class="col-2">@(item.Dishes?.Count() ?? 0)</div>
            <div class="col-2 d-flex justify-content-center gap-2">
                <a href="@Url.Action("EditCategory", "Category", new { id = item.Id })" class="btn btn-sm btn-outline-primary">
                    <i class="bi bi-pencil-square"></i>
                </a>
                <a href="@Url.Action("DetailsCategory", "Category", new { id = item.Id })" class="btn btn-sm btn-outline-info">
                    <i class="bi bi-info-circle"></i>
                </a>
                <a href="@Url.Action("DeleteCategory", "Category", new { id = item.Id })" class="btn btn-sm btn-outline-danger">
                    <i class="bi bi-trash"></i>
                </a>
            </div>
        </div>
    }
    <div class="my-3">
        <pagination page-model="@ViewBag.Model"></pagination>
    </div>
</div>

<div class="d-md-none">
    <div class="input-group mb-3 sticky-top bg-white pt-2 pb-2" style="top: 0; z-index: 1020;">
        <input type="text" class="form-control" id="mobileQuickSearch" placeholder="Quick search..."
               onkeyup="filterMobileCards(this.value)">
        <button class="btn btn-outline-secondary" type="button" data-bs-toggle="collapse"
                data-bs-target="#filterCollapse" aria-expanded="false">
            <i class="bi bi-sliders"></i>
        </button>
    </div>

    <div id="noResultsMessage" class="alert alert-info d-none">
        No categories match your search criteria
    </div>

    <div id="mobileCardContainer">
        @foreach (var item in Model)
        {
            <div class="card mb-3 category-card" data-name="@item.Name.ToLower()" data-desc="@item.Description.ToLower()">
                <div class="card-header d-flex justify-content-between align-items-center">
                    <h5 class="mb-0">@item.Name</h5>
                    <span class="badge bg-info">@(item.Dishes?.Count() ?? 0) Dishes</span>
                </div>
                <div class="card-body">
                    <p class="text-muted mb-3">@item.Description</p>
                    <div class="d-flex justify-content-between mt-3">
                        <a href="@Url.Action("DetailsCategory", "Category", new { id = item.Id })" class="btn btn-sm btn-outline-info">
                            <i class="bi bi-info-circle"></i> Details
                        </a>
                        <a href="@Url.Action("EditCategory", "Category", new { id = item.Id })" class="btn btn-sm btn-outline-primary">
                            <i class="bi bi-pencil-square"></i> Edit
                        </a>
                        <a href="@Url.Action("DeleteCategory", "Category", new { id = item.Id })" class="btn btn-sm btn-outline-danger">
                            <i class="bi bi-trash"></i> Delete
                        </a>
                    </div>
                </div>
                <div class="card-footer text-muted small">
                    <span>Created: @item.CreatedAt.ToString("dd/MM/yyyy")</span>
                </div>
            </div>
        }
    </div>

    <div class="my-3 d-flex justify-content-center">
        <pagination page-model="@ViewBag.Model"></pagination>
    </div>

    <script>
        function filterMobileCards(searchText) {
            searchText = searchText.toLowerCase();
            const cards = document.querySelectorAll('.category-card');
            let visibleCount = 0;

            cards.forEach(card => {
                const name = card.dataset.name;
                const desc = card.dataset.desc;

                if (name.includes(searchText) || desc.includes(searchText)) {
                    card.style.display = 'block';
                    visibleCount++;
                } else {
                    card.style.display = 'none';
                }
            });

            const noResultsMessage = document.getElementById('noResultsMessage');
            if (visibleCount === 0 && searchText !== '') {
                noResultsMessage.classList.remove('d-none');
            } else {
                noResultsMessage.classList.add('d-none');
            }
        }
    </script>
</div>