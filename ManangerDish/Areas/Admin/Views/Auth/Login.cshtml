@model ManagerDish.Models.DTO.LoginRequest
@{
    ViewData["Title"] = "Login";
    ViewData["Message"] = "Login";
    Layout = "";
}
<!-- CSS -->
<link rel="stylesheet" href="~/css/login.css" asp-append-version="true" />
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.12.1/font/bootstrap-icons.min.css">

<!-- LOGIN FORM -->
<div class="login-container">
    <div class="login-box">
        <h1>🍲 Manwah Hotpot</h1>
        <p class="subtitle">Đăng nhập để trải nghiệm ẩm thực tuyệt vời</p>

        <form method="post" id="loginForm">
            <!-- Username -->
            <div>
                <input asp-for="UserName" placeholder="Tên đăng nhập" id="username" />
                <span asp-validation-for="UserName" class="text-danger" style="font-size: 0.85em;"></span>
            </div>

            <!-- Password -->
            <div style="position: relative; margin-bottom: 0.5rem">
                <input asp-for="Password" type="password" placeholder="Mật khẩu" id="password" style="padding-right: 40px;" />
                <span style="position: absolute; top: 40%; right: 12px; transform: translateY(-50%); cursor: pointer; color: #FFD700;">
                    <i class="bi bi-eye" id="togglePassword"></i>
                </span>
                <span asp-validation-for="Password" class="text-danger" style="font-size: 0.85em;"></span>
            </div>

            <!-- Submit -->
            <button type="submit">Đăng nhập</button>
        </form>
    </div>
</div>

<!-- TOGGLE PASSWORD JS -->
<script>
    const inputPassword = document.getElementById("password");
    const eyeIcon = document.getElementById("togglePassword");

    eyeIcon.addEventListener("click", function () {
        const type = inputPassword.type === "password" ? "text" : "password";
        inputPassword.type = type;
        this.classList.toggle("bi-eye");
        this.classList.toggle("bi-eye-slash");
    });
</script>

@{
    <partial name="_ValidationScriptsPartial" />
}
