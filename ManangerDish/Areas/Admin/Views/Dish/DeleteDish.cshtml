@model Dish
@{
    ViewData["Title"] = "Delete Dish";
    ViewData["Message"] = "Delete Dish";
}

<div class="container py-4">
    <h1 class="mb-4">Delete Dish</h1>

    <div class="alert alert-danger">
        <h4>Are you sure you want to delete this dish?</h4>
        <p>This action cannot be undone.</p>
    </div>

    <div class="p-4 bg-light shadow-sm rounded">
        <div class="row">
            <div class="col-md-4 mb-4">
                <img src="@(string.IsNullOrEmpty(Model.Image) ? "/images/dishes/default-dish.png" : Model.Image)"
                     alt="@Model.Name" class="img-fluid rounded" style="width: 100%; max-height: 250px; object-fit: cover;" />
            </div>
            <div class="col-md-8">
                <dl class="row">
                    <dt class="col-sm-3">Name</dt>
                    <dd class="col-sm-9">@Model.Name</dd>

                    <dt class="col-sm-3">Description</dt>
                    <dd class="col-sm-9">@Model.Description</dd>

                    <dt class="col-sm-3">Price</dt>
                    <dd class="col-sm-9">$@Model.Price.ToString("0.00")</dd>

                    <dt class="col-sm-3">Category</dt>
                    <dd class="col-sm-9">@(Model.Category?.Name ?? "None")</dd>

                    <dt class="col-sm-3">Status</dt>
                    <dd class="col-sm-9"><span class="badge @(Model.Status == DishStatus.Available ? "bg-success" : "bg-danger")">@Model.Status</span></dd>

                    <dt class="col-sm-3">Created</dt>
                    <dd class="col-sm-9">@Model.CreatedAt.ToString("MMM dd, yyyy HH:mm")</dd>

                    <dt class="col-sm-3">Last Updated</dt>
                    <dd class="col-sm-9">@Model.UpdatedAt.ToString("MMM dd, yyyy HH:mm")</dd>
                </dl>

                @if (Model.OrderDetails != null && Model.OrderDetails.Any())
                {
                    <div class="alert alert-warning">
                        <strong>Warning:</strong> This dish has been ordered @Model.OrderDetails.Count() times.
                        Deleting it may affect order history. Consider changing its status to unavailable instead.
                    </div>
                }
            </div>
        </div>

        <form method="post" class="mt-4 pt-3 border-top">
            <input type="hidden" asp-for="Id" />
            <div class="d-flex justify-content-end">
                <a asp-controller="Dish" asp-action="Index" class="btn btn-secondary me-2">Cancel</a>
                <button type="submit" class="btn btn-danger">
                    <i class="bi bi-trash"></i> Delete
                </button>
            </div>
        </form>
    </div>
</div>