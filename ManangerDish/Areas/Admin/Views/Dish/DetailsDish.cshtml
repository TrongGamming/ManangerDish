@model Dish
@{
    ViewData["Title"] = "Dish Details";
    ViewData["Message"] = "Dish Details";
}

<div class="container py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1>Dish Details</h1>
        <div>
            <a asp-controller="Dish" asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-primary me-2">
                <i class="bi bi-pencil"></i> Edit
            </a>
            <a asp-controller="Dish" asp-action="Index" class="btn btn-secondary">
                <i class="bi bi-arrow-left"></i> Back to List
            </a>
        </div>
    </div>

    <div class="p-4 bg-light shadow-sm rounded">
        <div class="row">
            <div class="col-md-4 mb-4">
                <div class="card h-100">
                    <img src="@(string.IsNullOrEmpty(Model.Image) ? "/images/dishes/default-dish.png" : Model.Image)"
                         class="card-img-top" alt="@Model.Name" style="height: 250px; object-fit: cover;">
                    <div class="card-body">
                        <h5 class="card-title">@Model.Name</h5>
                        <p class="card-text">@Model.Description</p>
                        <div class="d-flex justify-content-between align-items-center">
                            <span class="h5 text-primary mb-0">$@Model.Price.ToString("0.00")</span>
                            <span class="badge @(Model.Status == DishStatus.Available ? "bg-success" : "bg-danger")">@Model.Status</span>
                        </div>
                    </div>
                </div>
            </div>
            <div class="col-md-8">
                <div class="card h-100">
                    <div class="card-body">
                        <h5 class="card-title">Dish Information</h5>
                        <dl class="row mt-3">
                            <dt class="col-sm-3">Name</dt>
                            <dd class="col-sm-9">@Model.Name</dd>

                            <dt class="col-sm-3">Description</dt>
                            <dd class="col-sm-9">@Model.Description</dd>

                            <dt class="col-sm-3">Price</dt>
                            <dd class="col-sm-9">$@Model.Price.ToString("0.00")</dd>

                            <dt class="col-sm-3">Category</dt>
                            <dd class="col-sm-9">@(Model.Category?.Name ?? "None")</dd>

                            <dt class="col-sm-3">Status</dt>
                            <dd class="col-sm-9">
                                <span class="badge @(Model.Status == DishStatus.Available ? "bg-success" : "bg-danger")">
                                    @Model.Status
                                </span>
                            </dd>

                            <dt class="col-sm-3">Created</dt>
                            <dd class="col-sm-9">@Model.CreatedAt.ToString("MMM dd, yyyy HH:mm")</dd>

                            <dt class="col-sm-3">Last Updated</dt>
                            <dd class="col-sm-9">@Model.UpdatedAt.ToString("MMM dd, yyyy HH:mm")</dd>

                            @if (Model.OrderDetails != null && Model.OrderDetails.Any())
                            {
                                <dt class="col-sm-3">Orders</dt>
                                <dd class="col-sm-9">@Model.OrderDetails.Count()</dd>
                            }
                        </dl>
                    </div>
                </div>

                @* @if (Model.DishSnapshots != null && Model.DishSnapshots.Any())
                {
                    <div class="card mt-4">
                        <div class="card-header">
                            <h5 class="card-title mb-0">Dish History</h5>
                        </div>
                        <div class="card-body">
                            <div class="table-responsive">
                                <table class="table table-striped table-hover">
                                    <thead>
                                        <tr>
                                            <th>Date</th>
                                            <th>Price</th>
                                            <th>Status</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @foreach (var snapshot in Model.DishSnapshots.OrderByDescending(s => s.CreatedAt).Take(5))
                                        {
                                            <tr>
                                                <td>@snapshot.CreatedAt.ToString("MMM dd, yyyy HH:mm")</td>
                                                <td>$@snapshot.Price.ToString("0.00")</td>
                                                <td>
                                                    <span class="badge @(snapshot.Status == DishStatus.Available ? "bg-success" : "bg-danger")">
                                                        @snapshot.Status
                                                    </span>
                                                </td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            </div>
                        </div>
                    </div>
                } *@
            </div>
        </div>
    </div>
</div>